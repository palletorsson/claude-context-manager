# Claude Context Manager — Environment Variables
# Copy this to .env and adjust as needed

# Path to Claude Code directory (auto-detected as ~/.claude if not set)
# CLAUDE_DIR=/home/user/.claude

# Backend server port (default: 8000)
# BACKEND_PORT=8000

# CORS origins (comma-separated, default: localhost:3000,3001)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Data directory for cache database (default: backend/data/)
# DATA_DIR=/path/to/data

# Frontend API URL (set in frontend/.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:8000
